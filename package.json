{
  "name": "compass-official-site",
  "private": true,
  "version": "3.0.0",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "optimize:images": "node scripts/optimize-images.mjs",
    "build": "npm run optimize:images && next build --webpack && node scripts/assemble-next-export.mjs",
    "verify": "node scripts/verify-next-build.mjs",
    "check": "npm run typecheck && npm run build && npm run verify"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "sharp": "0.34.5",
    "typescript": "5.9.3"
  }
}
